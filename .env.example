# ============================================================
# Clínica Saúde Integral — Agente Virtual
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Twilio (WhatsApp) ---
# Crie conta em twilio.com, ative o WhatsApp Sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número do Twilio Sandbox (padrão) ou número aprovado
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Meta / Instagram (Graph API) ---
# Crie um App no developers.facebook.com, configure webhook
META_PAGE_ACCESS_TOKEN=EAAxxxxxxx...
META_VERIFY_TOKEN=clinica_verify_token  # Qualquer string secreta que você escolher
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
